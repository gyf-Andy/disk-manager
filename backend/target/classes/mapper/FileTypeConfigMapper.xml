<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.diskmanager.mapper.FileTypeConfigMapper">
    
    <select id="selectEnabledExtensions" resultType="java.lang.String">
        SELECT extension FROM file_type_config 
        WHERE enabled = 1 AND deleted = 0
        ORDER BY sort_order
    </select>
    
</mapper>
