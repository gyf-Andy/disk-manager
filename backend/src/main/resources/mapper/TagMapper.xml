<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.diskmanager.mapper.TagMapper">
    
    <resultMap id="TagMap" type="com.diskmanager.entity.Tag">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="color" property="color"/>
        <result column="description" property="description"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>
    
    <select id="selectTagsByFileId" resultMap="TagMap">
        SELECT t.*
        FROM tag t
        INNER JOIN file_tag ft ON t.id = ft.tag_id
        WHERE ft.file_id = #{fileId} AND t.deleted = 0
        ORDER BY t.create_time DESC
    </select>
    
</mapper>
