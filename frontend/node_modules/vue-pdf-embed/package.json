{
  "name": "vue-pdf-embed",
  "version": "2.1.4",
  "description": "PDF embed component for Vue",
  "keywords": [
    "vue",
    "vuejs",
    "pdf"
  ],
  "license": "MIT",
  "author": "Aliaksei Hrynko (https://github.com/hrynko)",
  "main": "./dist/index.umd.js",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.umd.js",
      "types": "./dist/types/index.d.ts"
    },
    "./dist/index.essential.mjs": {
      "import": "./dist/index.essential.mjs",
      "types": "./dist/types/index.essential.d.ts"
    },
    "./dist/styles/": "./dist/styles/"
  },
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": "github:hrynko/vue-pdf-embed",
  "scripts": {
    "prepare": "husky && npm run build",
    "dev": "vite -c vite.config.dev.ts",
    "build": "vite build && vite build -c vite.config.essential.ts --emptyOutDir false",
    "postbuild": "vue-tsc -p tsconfig.build.json",
    "test": "vitest",
    "lint": "eslint . --fix",
    "format": "prettier . --write --ignore-unknown"
  },
  "dependencies": {
    "pdfjs-dist": "^4.10.38"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.3",
    "@vitejs/plugin-vue": "^4.6.2",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.5.1",
    "cssnano": "^7.1.2",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^15.7.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.6",
    "postcss-selector-parser": "^7.1.1",
    "prettier": "^3.8.1",
    "rollup-plugin-copy": "^3.5.0",
    "typescript": "^5.7.3",
    "vite": "^5.4.21",
    "vitest": "^2.1.1",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.12"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  }
}
